{
  "_comment": "Frammento di riferimento: questo è ciò che l'installer fonde in .claude/settings.json del progetto (merge non distruttivo). Gli script vivono in .ai-dev/adapters/claude-code/hooks/scripts/.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.ai-dev/adapters/claude-code/hooks/scripts/preEditGuard.mjs\"", "statusMessage": "AI-Dev Flow: guard file di test (read-only)" },
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.ai-dev/adapters/claude-code/hooks/scripts/preWorkSnapshot.mjs\"", "statusMessage": "AI-Dev Flow: valuto snapshot \"before\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.ai-dev/adapters/claude-code/hooks/scripts/postWorkVerification.mjs\"", "statusMessage": "AI-Dev Flow: verifica post-work" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(touch /tmp/aidevflow-prework-*)",
      "Bash(touch /tmp/aidevflow-verify-*)",
      "Bash(touch /tmp/aidevflow-testauthoring-*)"
    ]
  }
}
