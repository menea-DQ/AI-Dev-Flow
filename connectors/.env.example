# Credenziali dei connettori pronti. METTILE in .ai-dev/connectors.env del PROGETTO (gitignorato):
# i connettori caricano quel file da soli. NON metterle in connectors/ del plugin (cache, sovrascritta).
# In alternativa puoi esportarle nell'ambiente (hanno la precedenza). NON committare i segreti.

# Productive (ticketing)
PRODUCTIVE_API_TOKEN=
# Opzionale: usato solo se passi un id numerico nudo invece di un URL completo.
PRODUCTIVE_ORG_ID=

# Zammad (helpdesk)
ZAMMAD_API_TOKEN=
# Base URL dell'istanza Zammad (es. https://helpdesk.example.org). Usato dal contract-check (--check).
ZAMMAD_BASE_URL=
# Solo se l'istanza Zammad è dietro Cloudflare Access: cookie CF_Authorization
# da una sessione browser autenticata (DevTools → Application → Cookies).
ZAMMAD_CF_AUTHORIZATION=
