        <mxCell id="title" value="&lt;b&gt;Processo AI-Dev Flow v0.0.7 — 6 fasi · 3 gate umani · stato per-task · agenti per fase&lt;/b&gt;" style="text;html=1;fontSize=20;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1560" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="&lt;b&gt;Azzurro&lt;/b&gt;: automazione AI · &lt;b&gt;Verde&lt;/b&gt;: sub-agent dedicato (modello per fase) · &lt;b&gt;Arancio&lt;/b&gt;: GATE UMANO · &lt;b&gt;Viola&lt;/b&gt;: stato / knowledge-store · &lt;b&gt;Grigio&lt;/b&gt;: HOOK (guardiano deterministico, scatta sempre) · &lt;b&gt;Rosso&lt;/b&gt;: sistema esterno" style="text;html=1;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1560" height="30" as="geometry" />
        </mxCell>
        <mxCell id="principio" value="&lt;b&gt;Regola d'oro:&lt;/b&gt; il MECCANICO lo fa un hook/script (garantito) · il COGNITIVO lo fa un agente dedicato · le DECISIONI le prende l'umano · ogni deroga è esplicita e REGISTRATA" style="text;html=1;fontSize=12;align=center;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="1560" height="25" as="geometry" />
