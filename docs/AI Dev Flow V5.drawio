          <mxGeometry x="380" y="1830" width="320" height="75" as="geometry" />
        </mxCell>
        <mxCell id="eb1" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="r1" target="r2"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ==================== SIDEBAR ==================== -->
        <mxCell id="sb1" value="&lt;b&gt;STATO PER-TASK&lt;/b&gt;&lt;br&gt;.ai-dev/tasks/&amp;lt;id&amp;gt;/state.json — unico accesso: bin/flowState.mjs&lt;br&gt;&lt;br&gt;Registro di FATTI, non workflow engine: fase, gate approvati, branch+base, snapshot, verifiche (hash diff), doc-review, changelog, ticket, PR, DEROGHE motivate + log.&lt;br&gt;&lt;br&gt;★ Gli hook fanno rispettare i contratti di fase&lt;br&gt;★ Un task interrotto RIPRENDE da dov'era&lt;br&gt;★ Un collega può SUBENTRARE (stato committabile)&lt;br&gt;★ Sacrificabile: punta agli artefatti, non li contiene" style="rounded=1;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="360" width="420" height="290" as="geometry" />
        </mxCell>
        <mxCell id="sb2" value="&lt;b&gt;GUARDIANI (hook — scattano SEMPRE)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• versionDrift (SessionStart): drift versione + task in corso, VISIBILI all'utente&lt;br&gt;• preEditGuard: test read-only · niente codice senza spec+piano+branch · mai sul branch base&lt;br&gt;• preBashGuard: test read-only anche via shell&lt;br&gt;• perimeterGuard: solo componenti del kit&lt;br&gt;• preWorkSnapshot: &quot;before&quot; sui dati, a codice pristino&lt;br&gt;• postWorkVerification (Stop): verifica per hash del diff + checklist di chiusura&lt;br&gt;&lt;br&gt;Ogni valvola di sfogo = skip umano, motivato, registrato." style="rounded=1;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="670" width="420" height="300" as="geometry" />
        </mxCell>
        <mxCell id="sb3" value="&lt;b&gt;PERIMETRO DELLO STANDARD (enforced)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Nei progetti col kit si usano SOLO componenti del kit (+ Ponytail, abilitato dal kit). Skill personali e server MCP utente: BLOCCATI dall'hook.&lt;br&gt;Eccezioni: whitelist esplicite in flow.config.perimeter — decisione umana, committata." style="rounded=1;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="990" width="420" height="170" as="geometry" />
        </mxCell>
        <mxCell id="sb4" value="&lt;b&gt;AGENTI PER FASE — modello per natura del lavoro&lt;/b&gt;&lt;br&gt;&lt;br&gt;F0 intake → haiku (parsing meccanico)&lt;br&gt;F1 spec-author → opus (fase a più leverage)&lt;br&gt;F2 test-author → opus (test dal contratto, ISOLATO)&lt;br&gt;F3 test-runner → haiku (esegue e riporta)&lt;br&gt;F4 doc-author → sonnet (scrittura fedele)&lt;br&gt;F5 — (meccanica pura: script/hook)&lt;br&gt;&lt;br&gt;I sub-agent ricevono SOLO i loro input dichiarati (contratti fisici). I GATE restano SEMPRE all'orchestratore (skill flow): gli agenti preparano, l'utente decide." style="rounded=1;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="1180" width="420" height="290" as="geometry" />
        </mxCell>
        <mxCell id="sb5" value="&lt;b&gt;ENTRYPOINT: skill `flow`&lt;/b&gt;&lt;br&gt;&lt;br&gt;«Lavora su questo ticket» → l'orchestratore guida le 6 fasi leggendo lo stato: le fasi già registrate non si rifanno. Doctor invocabile in ogni momento. Risparmio: retrieval mirato, test solo su ciò che cambia, modelli per natura del lavoro, Ponytail per l'essenzialità." style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="1490" width="420" height="190" as="geometry" />
        </mxCell>
        <mxCell id="sb6" value="&lt;b&gt;STRATI&lt;/b&gt;: processo, artefatti .md e regole = AGNOSTICI dal tool · skill/hook/agenti/connettori = strato ADATTATORE Claude Code, sottile e sostituibile." style="rounded=1;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="1700" width="420" height="100" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
